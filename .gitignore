# Frontend-only GitHub repo
# Ignore everything by default, then allow only the Vite frontend app.
/*

!/.gitignore
!/frontend/
!/frontend/**

# Never track generated files or local secrets from the frontend app.
/frontend/node_modules/
/frontend/dist/
/frontend/.env
/frontend/.env.local
/frontend/.env.development
/frontend/.env.production
/frontend/.env.*.local

# General junk inside the frontend app.
/frontend/.DS_Store
/frontend/*.log
/frontend/npm-debug.log*
/frontend/yarn-debug.log*
/frontend/yarn-error.log*
/frontend/pnpm-debug.log*
/frontend/.vercel/
