# VITE_SITE_URL: public site URL used for canonical tags, Open Graph tags, and sitemap generation.
# Required for production builds.
VITE_SITE_URL="https://www.paktrack.xyz"
VITE_GOOGLE_SITE_VERIFICATION=""
VITE_GA_MEASUREMENT_ID=""

# VITE_API_BASE_URL: local backend base URL used only by the Vite dev proxy.
# The browser now calls /api/* and Vercel serverless functions proxy production requests.
VITE_API_BASE_URL="http://127.0.0.1:8000"
